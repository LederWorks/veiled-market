{#- features.yaml.j2 — v2.0.0 #}
{#- Feature flags for all enabled platforms (AI, IDE, CI, VCS).               #}
{#- Generated by atlas init; regenerated on atlas update.                    #}
{#- Variables: enabled_platforms (list of platform keys from platform.yaml)   #}
{#- Output: .config/features.yaml                                             #}
{#-                                                                           #}
{#- NOTE: enabled_ides, enabled_platforms, and languages are stored in        #}
{#- .config/atlas.json (the atlas state store) and must NOT be duplicated     #}
{#- here. This file tracks feature flags only.                                #}

{# ── AI Platforms ──────────────────────────────────────────────────────────── #}

{% if 'copilot-instructions' in enabled_platforms %}
copilot-cli:
  name: GitHub Copilot CLI
  category: ai
  enabled: true
  features:
    plugins: true
    skills: true
    commands: true
    agents: true
    hooks: true
    mcp_servers: false
    instructions: true
  config:
    hooks: .github/hooks/hooks.json
    instructions: .github/copilot-instructions.md
{% endif %}

{# ── IDE Platforms ─────────────────────────────────────────────────────────── #}

{% if 'cursor' in enabled_platforms %}
cursor:
  name: Cursor IDE
  category: ide
  enabled: true
  features:
    ai_built_in: true
    mcp_servers: true
    instructions: true
    plugin_ecosystem: false
  config:
    instructions: .cursorrules
    mcp: .cursor/mcp.json
{% endif %}

{% if 'vscode' in enabled_platforms %}
vscode:
  name: Visual Studio Code
  category: ide
  enabled: true
  features:
    ai_built_in: true
    mcp_servers: false
    instructions: true
    plugin_ecosystem: false
  config:
    instructions: .github/copilot-instructions.md
    settings: .vscode/settings.json
{% endif %}

{% if 'jetbrains' in enabled_platforms %}
jetbrains:
  name: JetBrains IDE
  category: ide
  enabled: true
  features:
    ai_built_in: true
    mcp_servers: false
    instructions: true
    plugin_ecosystem: false
  config:
    instructions: .github/copilot-instructions.md
{% endif %}

{# ── CI Platforms ──────────────────────────────────────────────────────────── #}

{% if 'github' in enabled_platforms %}
github:
  name: GitHub
  category: ci
  enabled: true
  features:
    instructions: true
    ai_cli_integration: true
    pipeline_automation: true
    marketplace: true
  config:
    instructions: .github/copilot-instructions.md
    workflows: .github/workflows/
{% endif %}

{% if 'azure-devops' in enabled_platforms %}
azure-devops:
  name: Azure DevOps
  category: ci
  enabled: true
  features:
    instructions: true
    ai_cli_integration: false
    pipeline_automation: true
    marketplace: false
  config:
    instructions: .github/copilot-instructions.md
{% endif %}

{# ── VCS Platforms ─────────────────────────────────────────────────────────── #}

{% if 'git' in enabled_platforms %}
git:
  name: Git
  category: vcs
  enabled: true
  features:
    instructions: true
    init_files: true
    commit_hooks: true
    branch_strategy: true
  config:
    gitignore: .gitignore
    gitattributes: .gitattributes
    instructions: .github/instructions/git.instructions.md
{% endif %}

{% if 'svn' in enabled_platforms %}
svn:
  name: Apache Subversion
  category: vcs
  enabled: true
  features:
    instructions: true
    init_files: false
    commit_hooks: false
    branch_strategy: false
  config:
    instructions: .github/instructions/svn.instructions.md
{% endif %}
